{
  "name": "commit-discipline",
  "version": "0.2.0",
  "description": "Validate AI-assisted commit messages",
  "type": "module",
  "bin": {
    "commit-discipline": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "pretest": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint .",
    "typecheck": "tsc --noEmit",
    "validate": "npm run typecheck && npm run lint && npm run test"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "oxlint": "^0.16.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.0"
  }
}
